# AI Provider
# Usamos el formato extendido apuntando al modelo 70b específico de OpenRouter
PROVIDER="meta-llama/llama-3.3-70b-instruct" 

# File patterns to include in review
# CORRECCIÓN: Estabas filtrando TypeScript/JavaScript. Cámbialo a Python.
FILE_PATTERNS="*.py"

# File patterns to exclude from review
EXCLUDE_PATTERNS="*test_*.py,test_*.py,venv/*,.venv/*"

# File containing code review rules
RULES_FILE="AGENTS.md"

# Strict mode
STRICT_MODE="true"

# Timeout in seconds
TIMEOUT="300"